# Copy to apps/api/.env and apps/web/.env.local as needed.
# Rename: copy env.example apps\api\.env

# API — Neon PostgreSQL (sslmode=require)
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# At least 32 characters (HS256)
JWT_SECRET=dev-dev-dev-dev-dev-dev-dev-dev-secret-32chars
JWT_EXPIRES_IN=1h

# 32-byte key: 64 hex chars OR base64 that decodes to 32 bytes
VOTE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

AI_SERVICE_URL=http://127.0.0.1:5001
CORS_ORIGIN=http://localhost:3000
PORT=4000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=app_password
EMAIL_FROM=no-reply@example.com
# Example (Gmail): SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# For Gmail, use an App Password (not your normal account password).

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
